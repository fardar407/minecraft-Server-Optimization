# Optional alert settings for Slack and email notifications
# Copy this file to alert_settings.env and fill in the values.
SLACK_WEBHOOK_URL=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
ALERT_TPS_THRESHOLD=18
ALERT_TPS_SAMPLE_LINES=50
MONITOR_LOG_FILE=logs/latest.log
