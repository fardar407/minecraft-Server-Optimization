# Optional server settings for start.bat, start.sh, modded_start.bat, modded_start.sh
# Run detect_server_specs.bat or detect_server_specs.sh to generate server_settings.env
SERVER_TYPE=paper
SERVER_JAR=paper.jar
XMS=8G
XMX=10G
PARALLEL_GC_THREADS=8
CONCURRENT_GC_THREADS=4
ACTIVE_PROCESSORS=8
JAVA_OPTS_EXTRA=-XX:+UseLargePages
